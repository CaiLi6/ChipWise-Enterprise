{
  "title": "Retrieval Quality",
  "uid": "chipwise-retrieval-quality",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Milvus Query QPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(chipwise_milvus_queries_total[5m]))",
          "legendFormat": "QPS"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 2,
      "title": "Milvus Query Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(chipwise_milvus_query_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(chipwise_milvus_query_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "title": "RRF Fusion: Raw vs Reranked Top-1 Score",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "chipwise_retrieval_raw_top1_score",
          "legendFormat": "Raw Top-1"
        },
        {
          "expr": "chipwise_retrieval_reranked_top1_score",
          "legendFormat": "Reranked Top-1"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 4,
      "title": "Semantic Cache Hit Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(chipwise_cache_hits_total[5m]) / rate(chipwise_cache_lookups_total[5m])",
          "legendFormat": "Hit Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 5,
      "title": "Cache Hits vs Misses",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(chipwise_cache_hits_total[5m])",
          "legendFormat": "Hits/s"
        },
        {
          "expr": "rate(chipwise_cache_lookups_total[5m]) - rate(chipwise_cache_hits_total[5m])",
          "legendFormat": "Misses/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ]
}
