{
  "title": "Ingestion Pipeline",
  "uid": "chipwise-ingestion-pipeline",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "queue",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(celery_queue_length, queue)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Celery Queue Backlog",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "celery_queue_length{queue=~\"$queue\"}",
          "legendFormat": "{{ queue }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 2,
      "title": "Celery Task Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(celery_tasks_total{queue=~\"$queue\"}[5m])) by (queue, state)",
          "legendFormat": "{{ queue }} - {{ state }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 3,
      "title": "PDF Extraction Strategy Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(chipwise_pdf_extractions_total) by (strategy)",
          "legendFormat": "{{ strategy }}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Daily New Chunks",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "increase(chipwise_chunks_ingested_total[24h])",
          "legendFormat": "Chunks/day"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "title": "Daily New Documents",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "increase(chipwise_documents_ingested_total[24h])",
          "legendFormat": "Docs/day"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "Embedding Service RPS + Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(chipwise_embedding_requests_total[5m]))",
          "legendFormat": "RPS"
        },
        {
          "expr": "sum(rate(chipwise_embedding_errors_total[5m]))",
          "legendFormat": "Errors/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 7,
      "title": "Embedding Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(chipwise_embedding_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
