# ChipWise Enterprise — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# PostgreSQL
PG_PASSWORD=changeme
POSTGRES_DB=chipwise

# Redis
REDIS_PASSWORD=
REDIS_MAXMEMORY=3gb

# JWT / Auth
JWT_SECRET_KEY=changeme-jwt-secret
SSO_CLIENT_SECRET=changeme-sso-secret

# LM Studio (runs separately, not in Docker)
# Ensure LM Studio is running at this URL
LM_STUDIO_URL=http://localhost:1234/v1
